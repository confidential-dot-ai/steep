#!/bin/sh
export PATH=/bin:/sbin:/usr/bin:/usr/sbin

mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev

echo "Loading SEV guest modules..."
modprobe ccp 2>/dev/null
modprobe sev-guest 2>/dev/null

sleep 1

echo "=== SNP ATTESTATION ==="
if [ -c /dev/sev-guest ]; then
    /bin/attestation-cli attest 2>/dev/null
else
    echo "WARNING: /dev/sev-guest not found"
fi
echo "=== END ATTESTATION ==="

# Wait for virtio disk and its partitions to appear
echo "Waiting for root disk..."
for i in $(seq 1 30); do
    [ -b /dev/vda1 ] && break
    sleep 0.5
done

if [ ! -b /dev/vda1 ]; then
    echo "ERROR: /dev/vda1 not found"
    ls /dev/vda* 2>/dev/null
    exec /bin/sh
fi

# Find the root partition (ext4) using busybox blkid output parsing
ROOT_DEV=""
CIDATA_DEV=""
for part in /dev/vda1 /dev/vda2 /dev/vda3; do
    [ -b "$part" ] || continue
    INFO=$(blkid "$part" 2>/dev/null)
    case "$INFO" in
        *TYPE=\"ext4\"*)
            ROOT_DEV="$part"
            ;;
        *TYPE=\"vfat\"*)
            CIDATA_DEV="$part"
            ;;
    esac
done

if [ -z "$ROOT_DEV" ]; then
    echo "ERROR: no ext4 root partition found"
    blkid /dev/vda* 2>/dev/null
    exec /bin/sh
fi

echo "Mounting root from $ROOT_DEV..."
mkdir -p /newroot
mount "$ROOT_DEV" /newroot

if [ ! -d /newroot/sbin ]; then
    echo "ERROR: root filesystem does not look valid"
    ls /newroot/
    exec /bin/sh
fi

# Mount the cidata/project partition (vfat) if present
if [ -n "$CIDATA_DEV" ]; then
    echo "Mounting cidata from $CIDATA_DEV..."
    mkdir -p /newroot/var/lib/cloud/seed/nocloud
    mount -o ro "$CIDATA_DEV" /newroot/var/lib/cloud/seed/nocloud
fi

# Clean up before switch_root
umount /proc
umount /sys

echo "Switching to root filesystem..."
exec switch_root /newroot /sbin/init
