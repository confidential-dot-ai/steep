#!/usr/bin/env bash
set -euo pipefail
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

set -x

echo "==> Installing system packages..."
sudo apt-get update
sudo apt install -y \
  # we need build tools and compilers etc
  build-essential \
  # debian-archive-keyring is required to install mkosi tools during build
  debian-archive-keyring

echo "==> Installing uv..."
which uv || curl -LsSf https://astral.sh/uv/install.sh | sh
. $HOME/.local/bin/env

echo "==> Installing mkosi..."
which mkosi || uv tool install git+https://github.com/systemd/mkosi.git@v26

echo "==> Installing rust..."
which cargo || curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
. $HOME/.cargo/env

echo "==> Installing igvm-tools..."
TOOLS_DIR="$DIR/../../igvm-tools"
test -d "$TOOLS_DIR" || git clone git@github.com:lunal-dev/igvm-tools.git "$TOOLS_DIR"
which igvm-tools || cargo install --path "$TOOLS_DIR"

SHARE_DIR="$HOME/.local/share/steep"
mkdir -p "$SHARE_DIR"

echo "==> Installing OVMF firmware..."
test -e "$SHARE_DIR/OVMF.fd" || cp "$TOOLS_DIR/examples/prebuilt/OVMF.fd" "$SHARE_DIR/OVMF.fd"

echo "==> Installing UKI..."
test -e "$SHARE_DIR/uki.efi" || cp "$TOOLS_DIR/examples/prebuilt/uki.efi" "$SHARE_DIR/uki.efi"

echo "==> Setup complete."
