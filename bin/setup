#!/usr/bin/env bash
set -euo pipefail
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

set -x

echo "==> Installing system packages..."
sudo apt-get update
# acpica-tools provides iasl, used at build time to compile the trusted
# DSDT (mkosi/base/acpi-tables/dsdt.asl) that gets injected into the
# initrd so the kernel's CONFIG_ACPI_TABLE_UPGRADE replaces the
# VMM-supplied DSDT at boot.
sudo apt install -y build-essential systemd-repart systemd-container qemu-utils genisoimage swtpm cpio acpica-tools

echo "==> Installing uv..."
which uv || curl -LsSf https://astral.sh/uv/install.sh | sh
test -e "$HOME/.local/bin/env" && . "$HOME/.local/bin/env"
which uv

echo "==> Installing mkosi..."
which mkosi || uv tool install git+https://github.com/systemd/mkosi.git@v26
which mkosi

echo "==> Installing rust..."
which cargo || curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
test -e "$HOME/.cargo/env" && . $HOME/.cargo/env
which cargo

BINSTALL_DISABLE_TELEMETRY=true
which cargo-binstall || curl -L --proto '=https' --tlsv1.2 -sSf https://raw.githubusercontent.com/cargo-bins/cargo-binstall/main/install-from-binstall-release.sh | bash
which cargo-binstall
which cargo-nextest || cargo binstall --no-confirm cargo-nextest
which cargo-nextest

echo "==> Setup complete."
