#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
cd $REPO_ROOT

set -x

# build and install the latest steep
cargo install

# build the base for use as read-only backing image
bin/steep base

# create a copy-on-write qcow2 image in ./output/caddy
bin/steep cloud-init examples/cloud-init/caddy

# boot qemu with the base image and the cloud-init config disk mounted
bin/steep run output/caddy

