# GPU kernel config fragment — enable loadable modules for the NVIDIA driver.
#
# Applied ONLY for the GPU base image, via
#   steep kernel  --kernel-config-fragment kernel/gpu.config
#   steep build   --kernel-config-fragment kernel/gpu.config --profile gpu
# (wired through the `build-gpu` Make target). steep's bare base image never
# sees this fragment, so the default hardened kernel stays module-free.
#
# WHY THIS EXISTS
# ---------------
# steep's hardening.config sets `# CONFIG_MODULES is not set` — a monolithic,
# module-free kernel is a deliberate attack-surface choice. But the NVIDIA
# open GPU kernel modules (nvidia.ko, nvidia-uvm.ko) are out-of-tree LOADABLE
# modules; there is no supported way to build them into vmlinux. So the GPU
# image must re-enable module loading. This fragment is that opt-in, and
# nothing more.
#
# WHAT THIS DOES *NOT* WEAKEN
# ---------------------------
# steep's configure phase runs `make mod2yesconfig` after merging fragments,
# which flips every in-tree tristate (=m) to built-in (=y). So even with
# CONFIG_MODULES=y, the kernel ships ZERO in-tree loadable modules — the only
# loadable modules in the running system are the two signed NVIDIA ones we
# bake into the dm-verity root. After the driver loads at boot, the gpu
# profile latches `kernel.modules_disabled=1` (nvidia-modules-latch.service),
# so no further module can ever load. The monolithic posture is preserved
# either side of a single boot-time driver load.
#
# INTEGRITY MODEL
# ---------------
# The module bytes live in the dm-verity-protected, measured rootfs, so their
# integrity is already guaranteed by the roothash → UKI → RTMR[2] chain and
# covered by attestation. The signatures below are NOT the trust root — they
# exist only because CONFIG_LOCK_DOWN_KERNEL_FORCE_CONFIDENTIALITY (set in
# hardening.config) refuses to load unsigned modules. We sign with the
# kernel build's auto-generated ephemeral key (certs/signing_key.pem, created
# by the build when MODULE_SIG=y and no key is pinned) whose public cert is
# embedded in — and therefore measured with — vmlinux. bin/steep-fetch-gpu
# signs the NVIDIA .ko with that key via scripts/sign-file; the private key is
# discarded with the build tree. See docs/GPU-IMAGE-PLAN.md decision D4.

# Loadable module support + the loader machinery.
CONFIG_MODULES=y
# We never unload the driver (load once at boot, then latch modules_disabled).
# Leaving MODULE_UNLOAD off keeps the unload path out of the kernel.
# CONFIG_MODULE_UNLOAD is not set

# Module signature enforcement — required for module loading to work at all
# under lockdown-confidentiality. FORCE rejects any unsigned/badly-signed
# module. SHA512 matches what bin/steep-fetch-gpu passes to sign-file. No
# MODULE_SIG_KEY is set, so the build auto-generates an ephemeral signing key
# (see the integrity-model note above).
CONFIG_MODULE_SIG=y
CONFIG_MODULE_SIG_FORCE=y
CONFIG_MODULE_SIG_ALL=y
CONFIG_MODULE_SIG_SHA512=y

# NVIDIA confidential-computing SPDM requires the Linux Kernel Crypto API
# (LKCA) backend for its GPU<->GSP session (ECDH key exchange + ECDSA/akcipher
# signatures over an elliptic curve). The driver's `crypto` conftest gates
# NV_CRYPTO_PRESENT on being able to include <crypto/ecc_curve.h>,
# <crypto/ecdh.h>, <crypto/internal/ecc.h> and <crypto/kpp.h>. steep's minimal
# kernel ships only the crypto dm-verity needs (SHA/AKCIPHER/GCM), so without
# these the driver builds libspdm against STUBS and CC init fails at runtime:
#   "libspdm expects LKCA but found stubs! SPDM cannot boot ... RmInitAdapter
#    failed" -> nvidia-smi reports "No devices were found" in the CC guest.
# Verified on a real B200 under KubeVirt: the driver loads and binds the GPU
# but cannot establish the SPDM session until these are present.
CONFIG_CRYPTO_ECC=y
CONFIG_CRYPTO_ECDH=y
CONFIG_CRYPTO_ECDSA=y
CONFIG_CRYPTO_KPP=y

# vsock — for the TDX quote path ONLY. The attestation service fetches TDX
# quotes from the host's Quote Generation Service over AF_VSOCK (guest ->
# host CID 2, port 4050). The alternative in-kernel ConfigFS-TSM GetQuote
# path works but is far too slow for a serving attestation endpoint
# (~1s+/quote), so vsock is the production path (tdx_quote_method="vsock"
# in the attest-gpu profile's config.toml). hardening.config documents that
# BOTH symbols are required (VIRTIO_VSOCKETS depends on VSOCKETS).
#
# Attack-surface containment: vsock is a host<->guest channel, so enabling
# it is a real (if small) surface increase. It is fenced at the unit level:
# attestation-api.service is the ONLY unit whose RestrictAddressFamilies=
# includes AF_VSOCK — every other long-running unit in the gpu/ssh/attest
# profiles carries a RestrictAddressFamilies= line WITHOUT it, so nothing
# else in the image can even create a vsock socket. The image ships no
# vsock listeners; the only traffic is the outbound GetQuote request.
CONFIG_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS=y

# NOTE (Stage 1/2 iteration): nvidia-uvm on coherent/ATS platforms wants
# CONFIG_HMM_MIRROR / CONFIG_ZONE_DEVICE / CONFIG_DEVICE_PRIVATE. On x86 GPU
# passthrough (our case) UVM works without them, so they are intentionally
# omitted here to keep the delta minimal. Add them only if the module build
# or `modprobe nvidia-uvm` at boot demands them. The symbols NVIDIA otherwise
# needs — MMU_NOTIFIER, X86_PAT, MTRR, FW_LOADER, DMA_SHARED_BUFFER — already
# resolve =y in the base config, so they are not repeated here.
