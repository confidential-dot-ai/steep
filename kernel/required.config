# Filesystems we mount inside the steep image
CONFIG_EROFS_FS=y
CONFIG_OVERLAY_FS=y
CONFIG_EXT4_FS=y
CONFIG_TMPFS=y

# Device mapper + dm-verity (verified root)
CONFIG_BLK_DEV_DM=y
CONFIG_DM_VERITY=y
CONFIG_DM_BUFIO=y

# dm-crypt for the ephemeral encrypted scratch overlay (aes-xts-plain64)
CONFIG_DM_CRYPT=y
CONFIG_CRYPTO_XTS=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_AES_NI_INTEL=y

# AMD SEV-SNP guest
CONFIG_AMD_MEM_ENCRYPT=y
CONFIG_X86_MEM_ENCRYPT=y
CONFIG_AMD_MEM_ENCRYPT_ACTIVE_BY_DEFAULT=y

# SEV-SNP guest attestation driver (/dev/sev-guest)
CONFIG_VIRT_DRIVERS=y
CONFIG_SEV_GUEST=y

# devtmpfs auto-mounted by kernel (initrd uses /dev)
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# Required under KubeVirt SEV-SNP: KubeVirt forces iommu_platform=true on every
# virtio device. Without VIRTIO_IOMMU the guest cannot drive any virtio device
# (virtio-blk hangs → /dev/vda2 never appears → initrd panics).
CONFIG_VIRTIO_IOMMU=y
