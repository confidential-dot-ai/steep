# Confidential VM kernel config overrides.
#
# This fragment inverts certain hardening choices for confos's confidential VM
# threat model where the initrd is measured (RTMR[2] for TDX, launch digest
# for SNP) and therefore part of the trust boundary rather than an attack
# surface.

# Re-enable ACPI table upgrade. In the standard Linux threat model this is
# risky because the initrd is untrusted. In confos's confidential VM model
# the initrd is measured into RTMR[2] (TDX) and bundled into the IGVM launch
# digest (SNP), so a tampered initrd fails attestation. We use this feature
# to ship a trusted DSDT that overrides VMM-supplied AML — defeats the
# BadAML attack vector.
CONFIG_ACPI_TABLE_UPGRADE=y

# Intel TDX guest support — required for the image to run inside an Intel
# Trust Domain. Adds /dev/tdx_guest and the kernel side of the
# TDREPORT / GetQuote ioctls. Without these, a confos image booted on a
# TDX host cannot generate TDX evidence. SEV-SNP guest support is set
# in kernel/required.config (CONFIG_SEV_GUEST=y); these are its TDX twins.
#
# INTEL_TDX_GUEST depends on X86_X2APIC (modern x86 APIC), which confos's
# hardening previously disabled. Re-enabling it is a small attack-surface
# tradeoff: X2APIC is the standard interrupt controller mode in QEMU/KVM
# and required for every TDX guest. Without it, the kernel won't even
# offer INTEL_TDX_GUEST as a Kconfig option.
CONFIG_X86_X2APIC=y
CONFIG_INTEL_TDX_GUEST=y
CONFIG_TDX_GUEST_DRIVER=y
