# Guest kernel config fragment for the `dev` mkosi profile.
#
# Pair this with `confos build --profile=dev --kernel-config-fragment kernel/dev.config`.
# The profile alone can't enable kernel drivers — it only edits the mkosi
# image contents — so any driver a debug affordance needs has to land here.
#
# Every entry below inverts a piece of confos's hardening baseline (see
# kernel/hardening.config for what gets rolled back). Do NOT ship production
# images with these on: they change the measurement AND the attack surface.

# 8250-compatible ISA UART driver. hardening.config disables CONFIG_SERIAL_8250
# for attack-surface reduction. KubeVirt only exposes an ISA serial port
# (`ttyS0`) via virt-launcher — without 8250 the guest cannot emit any kernel
# log there. `confos run` keeps using virtio-console (hvc0) and doesn't depend
# on this. Re-enabling 8250 lets the KubeVirt `virtctl console` /
# guest-console-log path surface boot logs; the console=ttyS0 cmdline flag
# lives in the paired mkosi profile.
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_PCI=y
CONFIG_SERIAL_8250_NR_UARTS=4
CONFIG_SERIAL_8250_RUNTIME_UARTS=4

# debugfs access for debugging builds. hardening.config resolves the
# debugfs access-mode choice to DEBUG_FS_ALLOW_NONE for production
# (lockdown exempts read-only debugfs files, so prod compiles the API to
# no-ops); this re-opens it. Merged last, so it wins the choice.
CONFIG_DEBUG_FS_ALLOW_ALL=y
