# Minimal virtio set (everything else off). VIRTIO_VSOCKETS used to be listed
# here but was silently dropped by olddefconfig all along (depends on VSOCKETS,
# which we never set), so the built kernel has never had vsock; to enable it,
# add both CONFIG_VSOCKETS=y and CONFIG_VIRTIO_VSOCKETS=y.
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y

# --- Confidentiality: keep the host out of guest memory ---
#
# In steep's threat model the host is untrusted. The following knobs
# either let the host inspect/reclaim guest memory or expose host-side
# filesystems into the guest — both violate the isolation the TEE gives
# us. Explicit `is not set` in this fragment because upstream
# x86_64_defconfig turns most of them on; without an explicit override
# they resurface after olddefconfig.
#
# Memory ballooning — the whole family. Host driving virtio-balloon lets
# it inflate/deflate the guest's RSS on demand, effectively giving the
# host a reclaim knob on confidential memory. Off.
# CONFIG_MEMORY_BALLOON is not set
# CONFIG_BALLOON_COMPACTION is not set
# CONFIG_VIRTIO_BALLOON is not set
# CONFIG_PAGE_REPORTING is not set

# Host-shared filesystems. 9P and virtio-fs are the two established
# ways to expose a host directory tree into a guest. Both cross the
# confidentiality boundary — anything the guest reads from a host share
# is host-controlled, anything it writes is host-visible. Off.
# CONFIG_NET_9P is not set
# CONFIG_NET_9P_VIRTIO is not set
# CONFIG_9P_FS is not set
# CONFIG_VIRTIO_FS is not set
# CONFIG_FUSE_FS is not set

# Disable large attack surfaces
# CONFIG_USB_SUPPORT is not set
# CONFIG_SOUND is not set
# CONFIG_DRM is not set
# CONFIG_WIRELESS is not set
# CFG80211 and MAC80211 live inside `if WIRELESS` in net/Kconfig, so the
# olddefconfig walker sees them =y in x86_64_defconfig and flips WIRELESS
# back to =y to satisfy the parent-child invariant. Unset the children so
# the parent stays off after olddefconfig.
# CONFIG_CFG80211 is not set
# CONFIG_MAC80211 is not set
# CONFIG_BLUETOOTH is not set
# CONFIG_INPUT_MISC is not set
# CONFIG_HW_RANDOM_VIRTIO is not set

# PCI hotplug + paravirt features (host-controllable; off in confidential VM)
# CONFIG_HOTPLUG_PCI is not set
# CONFIG_HOTPLUG_PCI_ACPI is not set
# CONFIG_HOTPLUG_PCI_PCIE is not set
# CONFIG_PCI_QUIRKS is not set
# CONFIG_PCI_ATS is not set
# CONFIG_PCI_IOV is not set
# CONFIG_PCI_PRI is not set
# CONFIG_PCI_PASID is not set
# CONFIG_PCI_LABEL is not set
# CONFIG_IOMMU_SVA is not set

# RDRAND-trusted RNG (no virtio-rng): nothing to set on kernel 6.12.
# ARCH_RANDOM was removed in 5.19 (arch RNG support is unconditional) and
# RANDOM_TRUST_CPU in 6.2 (CPU RNG trusted by default; opt out at boot with
# random.trust_cpu=off).

# Lockdown LSM in confidentiality mode (early)
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_SECURITY_LOCKDOWN_LSM_EARLY=y
CONFIG_LOCK_DOWN_KERNEL_FORCE_CONFIDENTIALITY=y

# Memory-safety hardening
CONFIG_STACKPROTECTOR=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_HARDENED_USERCOPY=y
CONFIG_SLAB_FREELIST_RANDOM=y
CONFIG_SLAB_FREELIST_HARDENED=y

# ACPI minimization
# CONFIG_ACPI_DOCK is not set
# CONFIG_ACPI_PROCESSOR is not set
# CONFIG_ACPI_HOTPLUG_CPU is not set
# CONFIG_ACPI_HOTPLUG_MEMORY is not set
# CONFIG_ACPI_CUSTOM_DSDT is not set
# CONFIG_ACPI_DEBUG is not set
# CONFIG_ACPI_PCI_SLOT is not set
# CONFIG_ACPI_BGRT is not set
# CONFIG_ACPI_TABLE_UPGRADE is not set

# Port-IO surface reduction (legacy devices off; switching console to hvc0)
# CONFIG_SERIAL_8250 is not set
# CONFIG_KEYBOARD_ATKBD is not set
# CONFIG_SERIO_I8042 is not set
# CONFIG_RTC_DRV_CMOS is not set
# CONFIG_PCSPKR_PLATFORM is not set

# No runtime modules; everything built-in (mod2yesconfig is defense-in-depth)
# CONFIG_MODULES is not set

# No debug info (smaller artifacts; one less reproducibility surface)
# CONFIG_DEBUG_INFO is not set
# CONFIG_LOCALVERSION_AUTO is not set

# =====================================================================
# KSPP (Kernel Self-Protection Project) recommended settings
# https://kspp.github.io/Recommended_Settings
#
# Full recommendation set for this build (kernel 6.12 / x86_64 / GCC).
# This block only lists options whose resolved state differs from the
# KSPP target; recommendations already satisfied above or by
# x86_64_defconfig are not restated:
#   STACKPROTECTOR[_STRONG], HARDENED_USERCOPY, SLAB_FREELIST_RANDOM,
#   SLAB_FREELIST_HARDENED, SECURITY_LOCKDOWN_LSM[_EARLY],
#   LOCK_DOWN_KERNEL_FORCE_CONFIDENTIALITY (all set above); BUG,
#   STRICT_KERNEL_RWX, DEBUG_WX, RANDOMIZE_BASE, RANDOMIZE_MEMORY,
#   MITIGATION_PAGE_TABLE_ISOLATION, X86_KERNEL_IBT, VMAP_STACK,
#   INIT_STACK_ALL_ZERO, SECCOMP[_FILTER], SECURITY, SLUB_DEBUG, WERROR,
#   COMPAT_BRK=n, COMPAT_VDSO=n, LEGACY_PTYS=n (defconfig).
#
# KSPP items intentionally NOT applied here (and why):
#   - GCC_PLUGIN_STRUCTLEAK: superseded by INIT_STACK_ALL_ZERO (=y), which
#     occupies the same mutually-exclusive stack-init Kconfig choice.
#   - CFI_CLANG / CFI_PERMISSIVE: Clang-only; steep builds with GCC.
#   - MODULE_SIG*: CONFIG_MODULES is off, so module signing is moot.
#   - RANDOM_TRUST_CPU / RANDOM_TRUST_BOOTLOADER: removed in 6.2 (CPU RNG
#     trusted by default). HW_RANDOM_TPM / TCG_TPM: steep exposes no vTPM
#     and relies on the RDRAND-trusted RNG (see the RNG note above).
#   - DEBUG_CREDENTIALS (removed 6.3) and SECURITY_WRITABLE_HOOKS (removed;
#     LSM hooks are const now): the symbols no longer exist.
#   - UBSAN_BOUNDS is left at its Kconfig default rather than forced =y:
#     the GCC bounds CC-gate symbol isn't present in this .config, so
#     forcing it risks being dropped by olddefconfig and failing the
#     fragment-verify. UBSAN + UBSAN_TRAP keep the bounds check on where
#     the compiler supports it.
#   - Boot-cmdline and sysctl recommendations live outside ./kernel and
#     are documented separately (most are redundant with the CONFIG
#     options below; the non-redundant ones — nosmt, slub_debug=ZF — are
#     perf/policy opt-ins).

# --- Kernel memory & data-structure integrity ---
CONFIG_BUG_ON_DATA_CORRUPTION=y
CONFIG_LIST_HARDENED=y
CONFIG_DEBUG_LIST=y
CONFIG_SCHED_STACK_END_CHECK=y
CONFIG_PAGE_TABLE_CHECK=y
CONFIG_PAGE_TABLE_CHECK_ENFORCED=y
# CONFIG_DEBUG_KERNEL is on, so these validators are available. They add
# runtime cost but catch corruption primitives early.
CONFIG_DEBUG_SG=y
CONFIG_DEBUG_VIRTUAL=y
CONFIG_DEBUG_NOTIFIERS=y

# --- Allocator hardening ---
CONFIG_SLAB_BUCKETS=y
CONFIG_RANDOM_KMALLOC_CACHES=y
CONFIG_SHUFFLE_PAGE_ALLOCATOR=y
# Don't merge same-size slab caches (harder cross-cache overflow).
# CONFIG_SLAB_MERGE_DEFAULT is not set
# Zero heap memory on allocation and on free.
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y
CONFIG_INIT_ON_FREE_DEFAULT_ON=y

# --- Stack & register scrubbing ---
CONFIG_RANDOMIZE_KSTACK_OFFSET_DEFAULT=y
CONFIG_ZERO_CALL_USED_REGS=y

# --- Compile-time overflow checking ---
CONFIG_FORTIFY_SOURCE=y

# --- Sanitizers: UBSAN in trap mode + KFENCE sampling ---
# UBSAN_TRAP faults on detected undefined behaviour instead of logging.
# The noisy / non-security sub-checks are turned off per KSPP.
CONFIG_UBSAN=y
CONFIG_UBSAN_TRAP=y
# CONFIG_UBSAN_SHIFT is not set
# CONFIG_UBSAN_DIV_ZERO is not set
# CONFIG_UBSAN_UNREACHABLE is not set
# CONFIG_UBSAN_SIGNED_WRAP is not set
# CONFIG_UBSAN_BOOL is not set
# CONFIG_UBSAN_ENUM is not set
# CONFIG_UBSAN_ALIGNMENT is not set
CONFIG_KFENCE=y
CONFIG_KFENCE_SAMPLE_INTERVAL=100

# --- GCC plugins ---
# Requires the GCC plugin headers in the kernel-builder tools tree:
# gcc-15-plugin-dev is added to mkosi/kernel-builder/mkosi.conf. Without
# it the GCC_PLUGINS menu is hidden and these are dropped by olddefconfig.
CONFIG_GCC_PLUGINS=y
CONFIG_GCC_PLUGIN_LATENT_ENTROPY=y
CONFIG_GCC_PLUGIN_STACKLEAK=y
# CONFIG_STACKLEAK_METRICS is not set
# CONFIG_STACKLEAK_RUNTIME_DISABLE is not set
CONFIG_RANDSTRUCT_FULL=y

# --- LSMs / userspace protections ---
CONFIG_SECURITY_YAMA=y
CONFIG_SECURITY_LANDLOCK=y
CONFIG_SECURITY_DMESG_RESTRICT=y
# Route all usermode-helper execution through a single (empty) path,
# which disables it entirely. steep runs no usermode helpers (modules are
# off), so nothing legitimately invokes call_usermodehelper.
CONFIG_STATIC_USERMODEHELPER=y
CONFIG_STATIC_USERMODEHELPER_PATH=""
# Don't let SELinux be disabled or softened at boot / runtime.
# CONFIG_SECURITY_SELINUX_BOOTPARAM is not set
# CONFIG_SECURITY_SELINUX_DEVELOP is not set
# CONFIG_SECURITY_SELINUX_DEBUG is not set

# --- x86_64 architecture hardening ---
CONFIG_X86_USER_SHADOW_STACK=y
CONFIG_MITIGATION_SLS=y
CONFIG_SCHED_CORE=y
CONFIG_DEFAULT_MMAP_MIN_ADDR=65536

# --- IOMMU: strict DMA, no passthrough, DMA off until IOMMU is up ---
CONFIG_IOMMU_DEFAULT_DMA_STRICT=y
# CONFIG_IOMMU_DEFAULT_PASSTHROUGH is not set
CONFIG_EFI_DISABLE_PCI_DMA=y

# --- Panic / fault behaviour (fail closed) ---
CONFIG_PANIC_ON_OOPS=y
CONFIG_PANIC_TIMEOUT=-1
CONFIG_MAGIC_SYSRQ_DEFAULT_ENABLE=0xb0
CONFIG_RESET_ATTACK_MITIGATION=y

# --- Attack-surface reduction: remove dangerous/legacy features ---
# Raw physical-memory / kernel-memory / MSR access. Lockdown already
# blocks the write paths at runtime; removing them at compile time is
# defence-in-depth.
# CONFIG_DEVMEM is not set
# CONFIG_PROC_KCORE is not set
# CONFIG_X86_MSR is not set
# Kernel-image replacement / persistence vectors.
# CONFIG_KEXEC is not set
# CONFIG_HIBERNATION is not set
# CONFIG_MODIFY_LDT_SYSCALL and CONFIG_X86_VSYSCALL_EMULATION are
# `bool "..." if EXPERT` (default y). Without EXPERT they aren't settable
# and olddefconfig forces them back on, silently ignoring the `is not set`
# lines below — so EXPERT must be on to turn them off.
CONFIG_EXPERT=y
# 32-bit compat and legacy syscall/ABI surface (steep images are 64-bit).
# CONFIG_COMPAT is not set
# CONFIG_IA32_EMULATION is not set
# CONFIG_X86_X32_ABI is not set
# CONFIG_MODIFY_LDT_SYSCALL is not set
# CONFIG_X86_VSYSCALL_EMULATION is not set
# Misc legacy surfaces.
# CONFIG_BINFMT_MISC is not set
# CONFIG_LEGACY_TIOCSTI is not set
# CONFIG_LDISC_AUTOLOAD is not set
# CONFIG_ACPI_CUSTOM_METHOD is not set
