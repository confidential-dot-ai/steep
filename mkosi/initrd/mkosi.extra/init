#!/bin/bash
set -u
export PATH=/usr/sbin:/usr/bin:/sbin:/bin

mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev

# Mirror all initrd output to ttyS0 (KubeVirt + most cloud QEMU bridge isa-serial
# to a host-visible log; hvc0 is not always wired up). Echoes still go to
# /dev/console too via stdio fan-out from the kernel.
if [ -e /dev/ttyS0 ]; then
    exec >/dev/ttyS0 2>&1
fi
echo "initrd: starting (output mirrored to ttyS0)"

# Parse roothash from kernel cmdline (disable globbing to prevent expansion)
set -f
ROOTHASH=""
for param in $(cat /proc/cmdline); do
    case "$param" in
        roothash=*) ROOTHASH="${param#roothash=}" ;;
    esac
done
set +f

if [ -z "$ROOTHASH" ]; then
    echo "FATAL: no roothash= on kernel cmdline"
    sleep 5
    echo b > /proc/sysrq-trigger
    exit 1  # fallback if sysrq disabled
fi

# Normalize to lowercase and validate: SHA-256 (64), SHA-384 (96), or SHA-512 (128) hex
ROOTHASH=$(echo "$ROOTHASH" | tr '[:upper:]' '[:lower:]')
if ! echo "$ROOTHASH" | grep -qE '^[a-f0-9]{64}([a-f0-9]{32})?([a-f0-9]{32})?$'; then
    echo "FATAL: invalid roothash (expected 64/96/128 hex chars): $ROOTHASH"
    sleep 5
    echo b > /proc/sysrq-trigger
    exit 1  # fallback if sysrq disabled
fi

echo "initrd: setting up dm-verity with roothash=$ROOTHASH"

# Wait for virtio disk to appear (up to 30 seconds)
WAITED=0
while [ ! -e /dev/vda2 ] && [ "$WAITED" -lt 30 ]; do
    sleep 1
    WAITED=$((WAITED + 1))
done
if [ ! -e /dev/vda2 ]; then
    echo "FATAL: /dev/vda2 not found after ${WAITED}s"
    echo b > /proc/sysrq-trigger
    exit 1  # fallback if sysrq disabled
fi

veritysetup open /dev/vda2 root /dev/vda3 "$ROOTHASH"
echo "initrd: dm-verity device created at /dev/mapper/root"

# Mount verified root as lower layer
mkdir -p /sysroot-lower /sysroot-upper /sysroot
mount -o ro /dev/mapper/root /sysroot-lower
echo "initrd: verified root mounted (read-only)"

# Pick overlay upper-layer backing. Scan virtio disks by whole-device label:
#   LABEL=scratch -> ephemeral, encrypted with a random in-RAM key (this boot)
#   LABEL=data    -> persistent, plaintext, also bind-mounted at /data
#   no label      -> claim it as data: wipefs + mkfs.ext4 -L data
#                    (confai's contract: this PVC is ours to format)
#   other label   -> leave alone (e.g. cidata for cloud-init NoCloud)
# Fall back to tmpfs if no usable disk is found (writes lost on reboot).
SCRATCH_DEV=""
DATA_DEV=""
for dev in /dev/vdb /dev/vdc /dev/vdd; do
    [ -e "$dev" ] || continue
    LABEL=$(blkid -s LABEL -o value "$dev" 2>/dev/null || true)
    echo "initrd: examining $dev (label=${LABEL:-<none>})"
    case "$LABEL" in
        scratch)
            [ -z "$SCRATCH_DEV" ] && SCRATCH_DEV="$dev"
            continue
            ;;
        data)
            [ -z "$DATA_DEV" ] && DATA_DEV="$dev"
            continue
            ;;
    esac
    if [ -n "$LABEL" ]; then
        # Some other recognized label (e.g. cidata for cloud-init NoCloud).
        # Leave it alone — not ours to touch.
        continue
    fi
    # No label — claim as data. wipefs+mkfs are belt-and-suspenders: blkid's
    # exit-code is unreliable on sparse PVCs.
    if [ -z "$DATA_DEV" ]; then
        echo "initrd: claiming $dev for data (wipefs + mkfs.ext4 -L data)"
        wipefs -a "$dev" >/dev/null 2>&1 || true
        if mkfs.ext4 -q -F -L data "$dev"; then
            DATA_DEV="$dev"
        else
            echo "initrd: WARNING: mkfs.ext4 on $dev failed; trying next device"
        fi
    fi
done

# Robust mount + overlay setup. Any failure here falls back to tmpfs so the
# guest can still boot — losing persistence is preferable to a kernel panic.
use_tmpfs_overlay() {
    echo "initrd: setting up tmpfs overlay (writes lost on reboot)"
    mount -t tmpfs tmpfs /sysroot-upper -o size=2G,nosuid,nodev
    mkdir -p /sysroot-upper/upper /sysroot-upper/work
    mount -t overlay overlay \
        -o lowerdir=/sysroot-lower,upperdir=/sysroot-upper/upper,workdir=/sysroot-upper/work \
        /sysroot
}

setup_persistent_overlay() {
    local dev="$1"
    mkdir -p /mnt/data
    if ! mount "$dev" /mnt/data; then
        echo "initrd: WARNING: mount $dev /mnt/data failed; falling back to tmpfs"
        return 1
    fi
    mkdir -p /mnt/data/overlay/upper /mnt/data/overlay/work
    if ! mount -t overlay overlay \
        -o lowerdir=/sysroot-lower,upperdir=/mnt/data/overlay/upper,workdir=/mnt/data/overlay/work \
        /sysroot; then
        echo "initrd: WARNING: overlay mount on $dev failed; falling back to tmpfs"
        umount /mnt/data 2>/dev/null || true
        return 1
    fi
    mkdir -p /sysroot/data
    mount --bind /mnt/data /sysroot/data || true
    echo "initrd: overlayfs mounted (persistent, backed by $dev, also at /data)"
    return 0
}

setup_scratch_overlay() {
    local dev="$1"
    echo "initrd: found scratch disk at $dev — ephemeral encrypted overlay"
    # Random per-boot key, kept only in (SEV-encrypted) RAM, never persisted.
    mkdir -p /run
    head -c 64 /dev/urandom > /run/scratch.key
    # --batch-mode: the disk carries an ext4 LABEL=scratch marker (written by the
    # host so we can find it via blkid); without -q cryptsetup detects that
    # signature and blocks on an interactive "Are you sure?" prompt the stdin-less
    # initrd can never answer. The mapping is plain-mode over a random per-boot key,
    # so the marker is meaningless to clobber and mkfs.ext4 rewrites it immediately.
    if ! cryptsetup open --batch-mode --type plain --cipher aes-xts-plain64 --key-size 512 \
        -d /run/scratch.key "$dev" scratch; then
        echo "initrd: WARNING: cryptsetup on $dev failed; falling back to tmpfs"
        return 1
    fi
    # Reformat every boot: prior contents are unrecoverable (key is gone) anyway.
    if ! mkfs.ext4 -q /dev/mapper/scratch \
       || ! mount /dev/mapper/scratch /sysroot-upper; then
        echo "initrd: WARNING: scratch mkfs/mount failed; falling back to tmpfs"
        return 1
    fi
    mkdir -p /sysroot-upper/upper /sysroot-upper/work
    if ! mount -t overlay overlay \
        -o lowerdir=/sysroot-lower,upperdir=/sysroot-upper/upper,workdir=/sysroot-upper/work \
        /sysroot; then
        echo "initrd: WARNING: scratch overlay failed; falling back to tmpfs"
        return 1
    fi
    echo "initrd: overlayfs mounted (ephemeral encrypted, backed by $dev)"
    return 0
}

if [ -n "$SCRATCH_DEV" ]; then
    if ! setup_scratch_overlay "$SCRATCH_DEV"; then
        use_tmpfs_overlay
    fi
elif [ -n "$DATA_DEV" ]; then
    if ! setup_persistent_overlay "$DATA_DEV"; then
        use_tmpfs_overlay
    fi
else
    echo "initrd: no data/scratch disk available"
    use_tmpfs_overlay
fi
echo "initrd: overlayfs ready"

# Minimal runtime directories
mkdir -p /sysroot/run/dbus /sysroot/var/log/journal

# Generate unique machine-id for this boot
cat /proc/sys/kernel/random/uuid | tr -d '-' > /sysroot/etc/machine-id

echo "initrd: switching root..."
exec switch_root /sysroot /sbin/init
